{
  "name": "three-realistic-vfx",
  "version": "0.1.0",
  "description": "High quality realistic VFX for Three.js — fire, smoke, explosions, muzzle flashes, and more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "demo": "cd demo && npm run dev"
  },
  "keywords": [
    "three",
    "threejs",
    "vfx",
    "particles",
    "fire",
    "smoke",
    "explosion",
    "muzzle-flash",
    "effects",
    "realistic",
    "react-three-fiber",
    "r3f"
  ],
  "author": "Glavin Wiechert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glavin001/three-realistic-vfx.git"
  },
  "peerDependencies": {
    "three": ">=0.150.0",
    "@react-three/fiber": ">=8.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "three.quarks": "^0.15.4"
  },
  "devDependencies": {
    "three": "^0.170.0",
    "@react-three/fiber": "^8.17.0",
    "@types/three": "^0.170.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
